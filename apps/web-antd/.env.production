VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api
# 配合nginx将/api代理到后端地址

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=gzip

# 是否开启 PWA
# 当前在本仓库依赖图下,vite-plugin-pwa@1.2 + Vite 7.3 组合开启后会触发
# jiti.mjs 的 "createRequire" externalize 错误(来自 generator chunk 静态分析)
# manifest/图标/iOS meta 已就位,定位 jiti 引入源后切回 true 即可
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
